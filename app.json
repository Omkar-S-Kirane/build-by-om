{
  "expo": {
    "name": "build-by-om",
    "slug": "build-by-om",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "buildbyom",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buildbyom.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a1a",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.buildbyom.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/project-images/newlogo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a1a",
          "image": "./assets/images/project-images/newlogo.png",
          "imageWidth": 120
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
